{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trova",
  "version": "0.1.0",
  "identifier": "com.fabio.trova",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Trova",
        "width": 1240,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "../scripts/local-backend.mjs",
      "../package.json",
      "../package-lock.json",
      "../node_modules/chokidar/**/*",
      "../node_modules/readdirp/**/*"
    ],
    "externalBin": [
      "binaries/trova-backend"
    ]
  }
}
